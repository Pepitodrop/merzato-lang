{
  "name": "merzato-lang",
  "version": "1.1.0",
  "description": "A multimodal art programming language combining Piet-style colour transitions, Velato-inspired musical intervals, MerzScript absurdism, and a bounded assembly VM.",
  "type": "module",
  "bin": {
    "merzato": "./src/cli.js"
  },
  "main": "./src/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js"
    },
    "./assembler": {
      "types": "./index.d.ts",
      "import": "./src/assembler.js"
    },
    "./art": {
      "types": "./index.d.ts",
      "import": "./src/artCompiler.js"
    },
    "./browser": {
      "types": "./index.d.ts",
      "import": "./src/browserHost.js"
    },
    "./errors": {
      "types": "./index.d.ts",
      "import": "./src/errors.js"
    },
    "./midi": {
      "types": "./index.d.ts",
      "import": "./src/midi.js"
    },
    "./validator": {
      "types": "./index.d.ts",
      "import": "./src/validator.js"
    },
    "./vm": {
      "types": "./index.d.ts",
      "import": "./src/vm.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src/",
    "examples/",
    "web/",
    "index.d.ts",
    "README.md",
    "SPEC.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-branches=70 --test-coverage-functions=90",
    "test:e2e": "node scripts/e2e-browser.js",
    "check": "node --check src/*.js && node --check web/*.js && node --check scripts/*.js && node scripts/check-version.js",
    "ci": "npm run check && npm test && npm run demo && npm run art && npm pack --dry-run",
    "demo": "node src/cli.js run examples/hello.mza",
    "art": "node src/cli.js art examples/hello.merz.svg examples/hello.mid",
    "serve": "python3 -m http.server 8080"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "programming-language",
    "esolang",
    "art-programming",
    "piet",
    "velato",
    "midi",
    "svg",
    "assembly",
    "virtual-machine",
    "turing-complete"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Pepitodrop/merzato-lang.git"
  },
  "bugs": {
    "url": "https://github.com/Pepitodrop/merzato-lang/issues"
  },
  "homepage": "https://pepitodrop.github.io/merzato-lang/",
  "author": "Luis Benedikt",
  "license": "MIT",
  "sideEffects": false
}
